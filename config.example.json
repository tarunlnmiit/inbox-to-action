{
  "triage_instructions": "I'm actively job hunting in ML/AI and backend engineering. Treat job alerts and recruiter emails with relevant roles as action_needed, not newsletter. Bank and card statements are fyi, not noise.",
  "rules": [
    { "field": "sender",  "contains": "hirist.tech",   "category": "action_needed" },
    { "field": "sender",  "contains": "stepstone",      "category": "action_needed" },
    { "field": "subject", "contains": "invoice",        "category": "noise" },
    { "field": "any",     "contains": "unsubscribe",    "category": "newsletter" }
  ],
  "accounts": [
    { "id": "personal", "kind": "gmail", "label": "Personal Gmail" },
    { "id": "work",     "kind": "gmail", "label": "Workspace", "client_secret": "client_secret.json" }
  ]
}
